rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Rule for Collection Group Queries on 'profile' subcollections
    // This allows findUserByEmail to look up profiles by email across all users
    match /{path=**}/profile/{profileId} {
      allow read: if request.auth != null;
    }

    // 2. Default rule for a user's entire private data tree
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }

    // 3. Rule for writing to your own profile explicitly (overriding the group block for updates)
    match /users/{userId}/profile/{profileId} {
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // 4. Sharing logic rules
    match /users/{userId}/shares/{shareId} {
      allow read, delete: if request.auth != null
                          && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
  }
}