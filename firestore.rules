rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: owners can read/write their own top-level user data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Allow any authenticated user to read profile docs (needed for findUserByEmail collectionGroup query)
    match /users/{userId}/profile/{profileId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // Allow any authenticated user to CREATE shares for any user (needed for sharing items)
    // Only the owner can read or delete their own shares
    match /users/{userId}/shares/{shareId} {
      allow read, delete: if request.auth != null
                          && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
  }
}
